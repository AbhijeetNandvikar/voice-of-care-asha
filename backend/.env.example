# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/voice_of_care

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# AWS Configuration
# Leave AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY empty to use IAM role (recommended for EC2/ECS)
# Only set these for local development or when IAM role is not available
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET_AUDIO=voice-of-care-audio
AWS_S3_BUCKET_REPORTS=voice-of-care-reports

# AWS Bedrock Configuration
# Model ID depends on your region and which models you have access to:
# 
# Claude 3 Sonnet (widely available):
#   anthropic.claude-3-sonnet-20240229-v1:0
#
# Claude 3.5 Sonnet (newer, may require special access):
#   anthropic.claude-3-5-sonnet-20241022-v2:0
#
# Cross-region inference profiles (only in us-east-1, us-west-2, eu-central-1):
#   us.anthropic.claude-3-5-sonnet-20241022-v2:0 (US)
#   eu.anthropic.claude-3-5-sonnet-20241022-v2:0 (EU)
#
# Check AWS Bedrock console → Model access to see which models are available
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Application Configuration
APP_ENV=development
DEBUG=True
