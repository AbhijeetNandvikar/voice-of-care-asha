# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/voice_of_care

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# AWS Configuration
# Leave AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY empty to use IAM role (recommended for EC2/ECS)
# Only set these for local development or when IAM role is not available
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET_AUDIO=voice-of-care-audio
AWS_S3_BUCKET_REPORTS=voice-of-care-reports

# AWS Bedrock Configuration
# Use inference profile for cross-region on-demand throughput
# Options: us.anthropic.claude-3-5-sonnet-20241022-v2:0 (US cross-region)
#          eu.anthropic.claude-3-5-sonnet-20241022-v2:0 (EU cross-region)
#          anthropic.claude-3-5-sonnet-20241022-v2:0 (direct model, requires provisioned throughput)
AWS_BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0

# Application Configuration
APP_ENV=development
DEBUG=True
